{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "DB: Start Postgres",
      "type": "shell",
      "command": "docker compose up -d db",
      "group": "build"
    },
    {
      "label": "Backend: Install",
      "type": "shell",
      "command": "pip install -r requirements.txt",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      }
    },
    {
      "label": "Backend: Dev",
      "type": "shell",
      "command": "uvicorn app.main:app --reload --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true
    },
    {
      "label": "Frontend: Install",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      }
    },
    {
      "label": "Frontend: Dev",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true
    }
  ]
}
